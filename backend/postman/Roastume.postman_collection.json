{
  "info": {
    "name": "Roastume API",
    "description": "Postman collection for Roastume backend APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "f523a8f9-fec9-4dff-bf7a-a50f5b9564a5"
  },
  "item": [
    {
      "name": "01 Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/health"
      }
    },
    {
      "name": "02 Register User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"postman_user_001\",\n  \"email\": \"postman_user_001@example.com\",\n  \"password\": \"Passw0rd!23\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/api/auth/register"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) {",
              "  const json = pm.response.json();",
              "  if (json.token) pm.environment.set('token', json.token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "03 Login User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"postman_user_001@example.com\",\n  \"password\": \"Passw0rd!23\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "  const json = pm.response.json();",
              "  if (json.token) pm.environment.set('token', json.token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "04 Get Me (Auth)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/auth/me"
      }
    },
    {
      "name": "05 Create Resume (Auth)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Backend Engineer Resume\",\n  \"field\": \"BACKEND WIZARDRY\",\n  \"details\": \"Built scalable APIs and observability dashboards.\",\n  \"isClassified\": false,\n  \"fileUrl\": \"{{uploadedFileUrl}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/api/resumes"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) {",
              "  const json = pm.response.json();",
              "  if (json.resume && json.resume.id) pm.environment.set('resumeId', json.resume.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "05A Upload Resume File (Auth)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": "{{baseUrl}}/api/resumes/upload"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) {",
              "  const json = pm.response.json();",
              "  if (json.file && json.file.url) pm.environment.set('uploadedFileUrl', json.file.url);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "06 List Resumes",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/resumes?page=1&limit=10&query=Backend"
      }
    },
    {
      "name": "07 Get Resume By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/resumes/{{resumeId}}"
      }
    },
    {
      "name": "08 Update Resume (Auth + Owner)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"details\": \"Updated from Postman test run.\",\n  \"isClassified\": true\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/api/resumes/{{resumeId}}"
      }
    },
    {
      "name": "09 Create Roast (Auth)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"resumeId\": \"{{resumeId}}\",\n  \"text\": \"Strong layout. Add quantified impact per role.\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/api/roasts"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) {",
              "  const json = pm.response.json();",
              "  if (json.roast && json.roast.id) pm.environment.set('roastId', json.roast.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "10 List Roasts By Resume",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/roasts/resume/{{resumeId}}"
      }
    },
    {
      "name": "11 Upsert Vote (Auth)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"roastId\": \"{{roastId}}\",\n  \"type\": \"up\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/api/votes"
      }
    },
    {
      "name": "12 Get Vote Summary",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/votes/roast/{{roastId}}"
      }
    },
    {
      "name": "13 Delete Vote (Auth)",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/votes/roast/{{roastId}}"
      }
    },
    {
      "name": "14 Delete Roast (Auth + Owner)",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/roasts/{{roastId}}"
      }
    },
    {
      "name": "15 Delete Resume (Auth + Owner)",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/resumes/{{resumeId}}"
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "token", "value": "" },
    { "key": "resumeId", "value": "" },
    { "key": "roastId", "value": "" }
  ]
}
